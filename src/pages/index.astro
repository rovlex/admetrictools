---
import BaseLayout from '../layouts/BaseLayout.astro';
import { calculatorList } from '../data/calculators';

const title = 'Free PPC Calculators for ROAS, CPC, CTR, and CPM';
const description = 'Free PPC calculators for ROAS, CPC, CTR, and CPM. Calculate core ad metrics with simple formulas, examples, and mobile-friendly tools.';
---

<BaseLayout title={title} description={description} path="/" breadcrumbItems={[{ name: 'Home', path: '/' }]}>
  <main id="content">
    <section class="home-hero">
      <div class="container narrow">
        <p class="eyebrow">PPC calculator hub</p>
        <h1>Free PPC Calculators</h1>
        <p class="lede">Calculate ROAS, CPC, CTR, and CPM with fast, mobile-friendly ad metric calculators.</p>
      </div>
    </section>

    <section class="container content-section" aria-labelledby="calculators-title">
      <div class="section-heading">
        <p class="eyebrow">Tools</p>
        <h2 id="calculators-title">Popular PPC calculators</h2>
      </div>
      <div class="cards-grid">
        {calculatorList.map((calculator) => (
          <a class="calculator-card-link" href={calculator.path}>
            <span>{calculator.name}</span>
            <p>{calculator.cardText}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="container content-section narrow text-section">
      <h2>Fast calculators for core ad metrics</h2>
      <p>Ad Metric Tools is a focused calculator hub for advertisers, PPC managers, ecommerce operators, and marketers who need quick answers without spreadsheets.</p>
      <p>Start with the <a href="/roas-calculator/">ROAS Calculator</a> to measure revenue efficiency, the <a href="/cpc-calculator/">CPC Calculator</a> to calculate cost per click, the <a href="/ctr-calculator/">CTR Calculator</a> to measure click-through rate, or the <a href="/cpm-calculator/">CPM Calculator</a> to compare cost per thousand impressions.</p>
      <p>Each calculator includes the formula, a worked example, frequently asked questions, and real HTML links to related PPC tools.</p>
    </section>
  </main>
</BaseLayout>
